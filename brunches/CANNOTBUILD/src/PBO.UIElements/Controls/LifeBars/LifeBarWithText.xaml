<Canvas x:Class="PokemonBattleOnline.PBO.UIElements.LifeBarWithText"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        DataContextChanged="LifeBar_DataContextChanged">
    <Canvas.Resources>
        <Storyboard x:Key="Flash" Completed="Storyboard_Completed">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="flash" Storyboard.TargetProperty="Opacity" RepeatBehavior="3x" Duration="0:0:0.10">
                <DiscreteDoubleKeyFrame Value="0" KeyTime="0:0:0.03"/>
                <DiscreteDoubleKeyFrame Value="1" KeyTime="0:0:0.07"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Canvas.Resources>
    <Rectangle Name="flash" Fill="#80303030" Height="3"/>
    <Border Name="bar" Height="3" BorderThickness="0,1"/>
    <TextBlock Name="Max" Canvas.Left="28" Canvas.Top="1" Foreground="White" FontSize="11" FontWeight="Bold" FontStyle="Italic" TextOptions.TextRenderingMode="Aliased"/>
    <TextBlock Name="Current" Canvas.Right="-24" Canvas.Top="1" Foreground="White" FontSize="11" FontWeight="Bold" FontStyle="Italic" TextOptions.TextRenderingMode="Aliased"/>
</Canvas>

<Border x:Class="LightStudio.PokemonBattle.PBO.Battle.Subtitle"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      Height="42" Width="256" IsHitTestVisible="False" BorderBrush="#99000000" BorderThickness="0,1">
    <Border BorderBrush="#99505050" BorderThickness="0,1">
        <Border BorderBrush="#99303030" Background="#99000000" BorderThickness="0,1">
            <TextBlock Name="textblock" Padding="4,3" TextWrapping="Wrap" VerticalAlignment="Bottom" MinHeight="{Binding ActualHeight,RelativeSource={RelativeSource AncestorType=Border}}" Foreground="#f8f8f8"/>
        </Border>
    </Border>
</Border>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="clr-namespace:LightStudio.PokemonBattle.PBO.UIElements"
                    xmlns:c="clr-namespace:LightStudio.PokemonBattle.PBO.Converters">
    <DataTemplate x:Key="Avatar">
        <Image Source="{Binding Converter={x:Static c:IdAvatar.C}}" Height="64" Width="64"/>
    </DataTemplate>
    <DataTemplate x:Key="User">
        <Grid Height="32" Width="150" Margin="1" Name="grid" Background="Transparent">
            <Grid.ContextMenu>
                <ContextMenu ItemsSource="{Binding Commands}" ItemContainerStyle="{x:Static ui:Controls.CommandMenu}"/>
            </Grid.ContextMenu>
            <Image Source="{Binding Avatar,Converter={x:Static c:IdAvatar.C}}" Height="32" Width="32" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Image Name="state" Height="11" Width="11" Margin="21,21,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <TextBlock Name="name" Text="{Binding Name}" Margin="45,2,0,0" VerticalAlignment="Top"/>
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding State}" Value="Afk">
                <Setter TargetName="state" Property="Source" Value="/PBO.UIElements;component/images/Avatars/afk.png"/>
                <Setter TargetName="name" Property="Foreground" Value="#666666"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding State}" Value="Aggressive">
                <Setter TargetName="state" Property="Source" Value="/PBO.UIElements;component/images/Avatars/aggressive.png"/>
                <Setter TargetName="name" Property="Foreground" Value="{x:Static ui:Brushes.MagentaM}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding State}" Value="Battling">
                <Setter TargetName="name" Property="Foreground" Value="#336699"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Commands.Count}" Value="0">
                <Setter TargetName="grid" Property="ContextMenu" Value="{x:Null}"/>
                <Setter TargetName="name" Property="FontStyle" Value="Italic"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>
</ResourceDictionary>

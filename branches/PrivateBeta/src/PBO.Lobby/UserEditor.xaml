<UserControl x:Class="LightStudio.PokemonBattle.PBO.Lobby.UserEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="clr-namespace:LightStudio.PokemonBattle.PBO.UIElements;assembly=PBO.UIElements"
             Background="#80ffffff">
    <Grid>
        <Grid.Resources>
            <Style TargetType="Button" BasedOn="{x:Static ui:Controls.XButton}">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Margin" Value="1"/>
                <Setter Property="Padding" Value="0"/>
            </Style>
        </Grid.Resources>
        <StackPanel Orientation="Horizontal">
            <Button Content="普通" Foreground="#333333" Background="#202020" BorderBrush="#000000" Click="normal_Click"/>
            <Button Content="离开" Foreground="#6699cc" Background="#336699" BorderBrush="#003366" Click="afk_Click"/>
            <Button Content="求战" Foreground="#ff8080" Background="#804040" BorderBrush="#800000" Click="aggressive_Click"/>
        </StackPanel>
        <Button Content="退出" Click="exit_Click" HorizontalAlignment="Right"/>
    </Grid>
</UserControl>

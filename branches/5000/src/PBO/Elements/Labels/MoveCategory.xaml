<ResourceDictionary	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
	                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:c="clr-namespace:PokemonBattleOnline.PBO.Converters">
    <DataTemplate x:Key="MoveCategoryLabel">
        <Image Name="img" Width="28" Height="14" SnapsToDevicePixels="True" Stretch="Uniform">
            <Image.ToolTip>
                <Binding Converter="{x:Static c:MoveCategoryText.C}"/>
            </Image.ToolTip>
        </Image>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding}" Value="Status">
                <Setter TargetName="img" Property="Source" Value="/PBO;component/images/Labels/Status.png"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding}" Value="Physical">
                <Setter TargetName="img" Property="Source" Value="/PBO;component/images/Labels/Physical.png"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding}" Value="Special">
                <Setter TargetName="img" Property="Source" Value="/PBO;component/images/Labels/Special.png"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>
</ResourceDictionary>

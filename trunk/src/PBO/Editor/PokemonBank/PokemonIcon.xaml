<UserControl x:Class="PokemonBattleOnline.PBO.Editor.PokemonIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:PokemonBattleOnline.PBO.Elements"
             xmlns:e="clr-namespace:PokemonBattleOnline.PBO.Editor"
             Cursor="Hand" AllowDrop="True">
    <UserControl.ToolTip>
        <StackPanel DataContext="{Binding Model}" Background="{x:Static ui:SBrushes.GrayF}">
            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
            <TextBlock Text="{Binding Moves[0]}"/>
            <TextBlock Text="{Binding Moves[1]}"/>
            <TextBlock Text="{Binding Moves[2]}"/>
            <TextBlock Text="{Binding Moves[3]}"/>
        </StackPanel>
    </UserControl.ToolTip>
    <UserControl.ContextMenu>
        <ContextMenu>
            <MenuItem Header="复制"/>
            <Separator/>
            <MenuItem Header="删除"/>
        </ContextMenu>
    </UserControl.ContextMenu>
    <Grid>
        <Image Name="icon" Height="32" Width="32" Source="{Binding Icon}"/>
    </Grid>
</UserControl>

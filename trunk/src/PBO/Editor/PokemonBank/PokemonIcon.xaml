<UserControl x:Class="PokemonBattleOnline.PBO.Editor.PokemonIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="clr-namespace:PokemonBattleOnline.PBO.Elements">
    <UserControl.ToolTip>
        <ToolTip Background="{x:Static ui:SBrushes.GrayF}">
            <StackPanel DataContext="{Binding Model}">
                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                <TextBlock Text="{Binding Moves[0]}"/>
                <TextBlock Text="{Binding Moves[1]}"/>
                <TextBlock Text="{Binding Moves[2]}"/>
                <TextBlock Text="{Binding Moves[3]}"/>
            </StackPanel>
        </ToolTip>
    </UserControl.ToolTip>
    <UserControl.ContextMenu>
        <ContextMenu ItemsSource="{Binding Commands}" ItemContainerStyle="{x:Static ui:Controls.CommandMenu}"/>
    </UserControl.ContextMenu>
    <Grid>
        <Rectangle x:Name="iconbg" Width="32" Height="32" Fill="{x:Static ui:SBrushes.SelectedItemBg}" Visibility="Hidden"/>
        <Image Height="32" Width="32" Source="{Binding Icon}"/>
    </Grid>
</UserControl>

<UserControl x:Class="LightStudio.PokemonBattle.PBO.Battle.NDS"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:my="clr-namespace:LightStudio.PokemonBattle.PBO.Battle">
    <UserControl.Resources>
        <ResourceDictionary Source="/PBO.Battle;component/NDS/StateBars.xaml"/>  
    </UserControl.Resources>
    <Canvas Height="384" MinWidth="256" MaxWidth="256">
        <my:BattleField2D x:Name="board"/>
        <ListBox x:Name="opms" ItemTemplate="{StaticResource ResourceKey=OStateBar}" SnapsToDevicePixels="True" Background="{x:Null}" Canvas.Right="-1" Canvas.Top="105" BorderThickness="0" Padding="0" HorizontalContentAlignment="Right" IsHitTestVisible="False" IsTabStop="False">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Canvas Height="31" Width="114">
                                    <ContentPresenter Name="cp" Canvas.Top="2" Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}"/>
                                </Canvas>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard Name="shake">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="cp" Storyboard.TargetProperty="(Canvas.Top)" Duration="00:00:01">
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="2"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.16" Value="3"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.28" Value="4"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.41" Value="3"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.53" Value="2"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.65" Value="1"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.77" Value="0"/>
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.89" Value="1"/>
                                                    </DoubleAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="shake"/>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="HasContent" Value="False">
                            <Setter Property="Visibility" Value="Hidden"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
        <ItemsControl x:Name="rpms" SnapsToDevicePixels="True" Background="{x:Null}" Canvas.Left="-1" ItemTemplate="{StaticResource ResourceKey=RStateBar}" Canvas.Top="29" HorizontalContentAlignment="Left">
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Style.Triggers>
                        <Trigger Property="Content" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Hidden"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ItemsControl.ItemContainerStyle>
        </ItemsControl>
        <my:Subtitle x:Name="subtitle" Canvas.Top="147"/>
        <my:ControlPanel x:Name="cp" Canvas.Bottom="0"/>
    </Canvas>
</UserControl>

<UserControl x:Class="LightStudio.PokemonBattle.PBO.Battle.BattleReport"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid UseLayoutRounding="True">
        <FlowDocumentScrollViewer Name="reportViewer" IsToolBarVisible="False" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Visible" SnapsToDevicePixels="True" BorderThickness="0">
            <FlowDocument Name="report" FontSize="15" PagePadding="0" FontFamily="Microsoft YaHei">
                <FlowDocument.Resources>
                    <Style TargetType="Paragraph">
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </FlowDocument.Resources>
            </FlowDocument>
        </FlowDocumentScrollViewer>
        <Button Content="B" Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Center" Click="previousTurn_Click"/>
    </Grid>
</UserControl>

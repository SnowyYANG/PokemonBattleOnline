<Window x:Class="LightStudio.PokemonBattle.PBO.Battle.BattleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:my="clr-namespace:LightStudio.PokemonBattle.PBO.Battle"
        xmlns:ui="clr-namespace:LightStudio.PokemonBattle.PBO.UIElements;assembly=PBO.UIElements"
        ResizeMode="CanMinimize" Title="等待主机开始对战" SizeToContent="WidthAndHeight">
    <Grid Height="545" Width="750">
        <Canvas Background="#f5f5f5" Width="266" HorizontalAlignment="Left">
            <my:NDS x:Name="nds"/>
            <ContentControl x:Name="pmReview" ContentTemplate="{x:Static ui:Cartes.Pokemon}" HorizontalAlignment="Left" VerticalAlignment="Top" Canvas.Top="384"/>    
        </Canvas>
        <my:BattleReport x:Name="br" Margin="266,0,0,0"/>
        <Label x:Name="mask" Content="请稍候..." Background="Black" Foreground="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>           
    </Grid>
</Window>
